programa  
{  
    funcao inicio()  
    {  
                        
        inteiro numero
  
        escreva ("Digite um número: ")  
        leia (numero)  
          
        se (numero % 2 == 0)  
        {  
            escreva ("É par")  
        }  
        senao  
        {  
            escreva ("É ímpar")  
        }  
          
    }  
}  